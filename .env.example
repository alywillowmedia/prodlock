# Shopify
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SCOPES=read_products,write_products,read_themes,write_themes
SHOPIFY_APP_URL=https://your-prodlock-app.vercel.app

# Optional if you use a custom myshopify domain mapping flow
# SHOP_CUSTOM_DOMAIN=shop.yourdomain.com

# Supabase Postgres
# Runtime: use the Supavisor transaction pooler (port 6543) on Vercel.
DATABASE_URL=postgresql://prisma.pgjuehraisoxgovpyooh:your_db_password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Migrations: use the direct connection string or session pooler (port 5432).
DIRECT_URL=postgresql://postgres:your_db_password@db.pgjuehraisoxgovpyooh.supabase.co:5432/postgres

# If you are temporarily unblocking a deployment and do not yet have DIRECT_URL set,
# the app now falls back to DATABASE_URL for Prisma CLI commands.
# Keeping a real DIRECT_URL is still the better production setup.

NODE_ENV=production
PORT=3000
